digraph SSA {
  rankdir=TB;
  newrank=true;
  ranksep=0.9;
  nodesep=0.35;
  splines=true;
  fontname="Helvetica";
  node [fontname="Menlo"];
  edge [fontname="Menlo"];
  subgraph cluster_f0 {
    color="#90a4ae"; style="rounded,filled"; fillcolor="#f3f7fa"; penwidth=1.4;
    margin=16;
    labelloc=t; label="+";
    f0_order [shape=point, style=invis, width=0, height=0, label=""];
  }
  subgraph cluster_f1 {
    color="#90a4ae"; style="rounded,filled"; fillcolor="#f3f7fa"; penwidth=1.4;
    margin=16;
    labelloc=t; label="-";
    f1_order [shape=point, style=invis, width=0, height=0, label=""];
  }
  subgraph cluster_f2 {
    color="#90a4ae"; style="rounded,filled"; fillcolor="#f3f7fa"; penwidth=1.4;
    margin=16;
    labelloc=t; label="*";
